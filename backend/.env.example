# --- 실행 환경 ---
ENV=development
LOG_LEVEL=INFO

# --- 데이터베이스 ---
# 로컬: SQLite. 프로덕션(Railway): postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./atm_ledger.db

# --- JWT ---
# openssl rand -hex 32 로 생성
JWT_SECRET=change-me-to-a-random-64-char-hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# --- CORS ---
# 콤마로 구분. Vercel 프론트 URL 추가
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google OAuth (소셜 로그인) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# id_token 검증 시 허용할 추가 client_id (콤마 구분).
# Capacitor Android 앱은 google-services.json 의 client_id 로 audience 발급 → 웹 client_id 와 다름.
# Firebase Console > Android 앱 > google-services.json 안의 oauth_client 두 개 (type=1 Android, type=3 Web) 모두 등록.
# 예: 845731980768-xxxxxx.apps.googleusercontent.com,845731980768-yyyyyy.apps.googleusercontent.com
GOOGLE_EXTRA_CLIENT_IDS=

# --- Google Maps Platform (서버 키 — Geocoding API) ---
# 미설정 시 자동으로 Nominatim 으로 fallback. Render IP 제한 권장.
# https://console.cloud.google.com/google/maps-apis/api-list 에서 발급.
GOOGLE_MAPS_SERVER_KEY=

# --- Firebase Admin SDK (FCM 푸시 알림) ---
# Firebase Console > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성" → JSON 다운로드.
# 그 JSON 파일 내용 전체를 raw 그대로 (개행 포함) 또는 base64 로 인코딩해서 환경변수에 넣음.
# Render 권장: Secret File 로 업로드 또는 base64 인코딩 후 단일 환경변수.
# 미설정 시 FCM 발송이 graceful disable — 백엔드 부팅에는 영향 없음.
FIREBASE_CREDENTIALS_JSON=

# --- Kakao OAuth (v2 예정 - 비워둬도 됨) ---
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# --- 파일 저장소 ---
# local | r2 (Cloudflare R2 / S3 호환)
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# R2 사용 시
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=atm-ledger-photos
R2_PUBLIC_BASE_URL=

# --- 프론트엔드 BASE URL (이메일 인증 링크 등에 사용) ---
FRONTEND_BASE_URL=http://localhost:5173

# --- Resend (이메일 발송, 비밀번호 찾기 메일 등) ---
# RESEND_API_KEY 가 비어 있으면 reset 링크를 백엔드 로그에 출력만 함(개발 폴백).
# 프로덕션: https://resend.com 에서 가입 → API Key 발급 → Domains 에서 도메인 검증
#   (moa365.com / moa.atm.ai.kr 등 발신 도메인의 SPF/DKIM/DMARC DNS 레코드 추가, ~24h 전파).
# 도메인 검증 전이라도 onboarding@resend.dev 발신은 본인 계정 이메일에만 발송 가능.
RESEND_API_KEY=
RESEND_FROM=Moa AI 가계부 <onboarding@resend.dev>
PASSWORD_RESET_TTL_MIN=60

# --- Toss Payments (실 결제, 한국 PG) ---
# tosspayments.com 가맹 신청 → 개발자센터에서 키 발급.
# 테스트 키 먼저(test_sk_*/test_ck_*)로 통합 검증 → 라이브 키로 전환.
# 키 미설정 시 결제 엔드포인트가 503 으로 graceful disable, MyPage 결제 탭은 mock 모드.
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=
TOSS_MONTHLY_PRICE_KRW=5400
TOSS_MONTHLY_ORDER_NAME=Moa AI 가계부 월 정기결제

# --- Lemon Squeezy (Merchant of Record, 글로벌 카드/페이팔) ---
# Toss(KRW 즉시) 와 병존 — 사용자가 결제 페이지에서 선택. 키 미설정 시 LS 엔드포인트 503.
#
# 발급 방법:
#   1) API Key
#      https://app.lemonsqueezy.com/settings/api  → "New API key" → 복사
#   2) Webhook secret
#      Dashboard > Settings > Webhooks > "Add webhook"
#        URL = https://atm-ledger.onrender.com/webhooks/lemonsqueezy
#        Events: subscription_created, subscription_updated, subscription_cancelled,
#                subscription_resumed, subscription_expired,
#                subscription_payment_success, subscription_payment_failed
#      → 생성 시 표시되는 "Signing secret" 을 그대로 복사 (한 번만 노출).
#   3) Store slug
#      체크아웃 URL 의 서브도메인 — 예: https://atmstore.lemonsqueezy.com → atmstore
#   4) Variant ID (월/연 각각)
#      Products > 해당 상품 > Variants > 각 variant 의 "Copy ID" 또는
#      체크아웃 URL 끝 UUID (예: b5d0282a-f73f-41f4-87f2-e7513279ded2)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_SLUG=
LEMONSQUEEZY_VARIANT_ID_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_YEARLY=

# --- 베타 기간 무료 모드 ---
# true (현재): 모든 사용자가 paid 와 동일한 권한, 결제 비활성, 엑셀 등 유료 기능 무료 개방.
#              UI 결제 탭에 "베타 기간 무료" 안내. Toss 키가 있어도 결제 API 는 409 차단.
# false: 정식 유료화 — 트라이얼 30일 후 paid 만 엑셀 가능. Toss 키 있으면 실 결제, 없으면 mock.
BETA_FREE_MODE=true

# --- 관리자 (Admin) ---
# 콤마 구분 이메일 화이트리스트. 여기에 등록된 이메일로 가입·로그인한 사용자만
# /admin/* 엔드포인트와 프론트 /admin 페이지에 접근 가능. 대소문자 무관 비교.
# Moa AI 가계부 운영자 이메일을 콤마로 추가. 예: primary@example.com,backup@example.com
# 잠금 복구용 백업 이메일을 미리 한 개 더 등록해두면 즉시 관리자 권한 회복 가능.
ADMIN_EMAILS=aitrendmarketer@gmail.com

# 공식 문의처 (Landing FAQ·푸터·고객 안내에 노출)
SUPPORT_EMAIL=master@aitrend.kr
