# --- 실행 환경 ---
ENV=development
LOG_LEVEL=INFO

# --- 데이터베이스 ---
# 로컬: SQLite. 프로덕션(Railway): postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./atm_ledger.db

# --- JWT ---
# openssl rand -hex 32 로 생성
JWT_SECRET=change-me-to-a-random-64-char-hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# --- CORS ---
# 콤마로 구분. Vercel 프론트 URL 추가
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google OAuth (소셜 로그인) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Kakao OAuth (v2 예정 - 비워둬도 됨) ---
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# --- 파일 저장소 ---
# local | r2 (Cloudflare R2 / S3 호환)
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# R2 사용 시
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=atm-ledger-photos
R2_PUBLIC_BASE_URL=

# --- 프론트엔드 BASE URL (이메일 인증 링크 등에 사용) ---
FRONTEND_BASE_URL=http://localhost:5173

# --- Resend (이메일 발송, 비밀번호 찾기 메일 등) ---
# RESEND_API_KEY 가 비어 있으면 reset 링크를 백엔드 로그에 출력만 함(개발 폴백).
# 프로덕션: https://resend.com 에서 가입 → API Key 발급 → Domains 에서 도메인 검증
#   (moa.atm.ai.kr 의 SPF/DKIM/DMARC DNS 레코드 추가, ~24h 전파).
# 도메인 검증 전이라도 onboarding@resend.dev 발신은 본인 계정 이메일에만 발송 가능.
RESEND_API_KEY=
RESEND_FROM=Moa AI 가계부 <onboarding@resend.dev>
PASSWORD_RESET_TTL_MIN=60

# --- Stripe Subscriptions (실 결제) ---
# Stripe Dashboard → Developers → API keys 에서 발급. test mode 는 sk_test_/pk_test_ 시작.
# Products → 새 Recurring Price 등록(월 $4) → 그 price 의 id 를 STRIPE_PRICE_ID 에.
# Webhook 은 Stripe Dashboard 또는 stripe-cli 로 endpoint 등록 후 signing secret 발급:
#   prod: https://<api-domain>/webhooks/stripe
#   local: stripe listen --forward-to localhost:8000/webhooks/stripe → signing secret 출력
# 이 4개 중 하나라도 비어 있으면 결제 엔드포인트는 503 으로 graceful disable 됩니다.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- 관리자 (Admin) ---
# 콤마 구분 이메일 화이트리스트. 여기에 등록된 이메일로 가입·로그인한 사용자만
# /admin/* 엔드포인트와 프론트 /admin 페이지에 접근 가능. 대소문자 무관 비교.
# Moa AI 가계부 운영자 이메일을 콤마로 추가. 예: primary@example.com,backup@example.com
# 잠금 복구용 백업 이메일을 미리 한 개 더 등록해두면 즉시 관리자 권한 회복 가능.
ADMIN_EMAILS=aitrendmarketer@gmail.com

# 공식 문의처 (Landing FAQ·푸터·고객 안내에 노출)
SUPPORT_EMAIL=master@aitrend.kr
