{
  "name": "moa-ai-ledger-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "vite build --mode mobile",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "typecheck": "tsc -b",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "android:dev": "npm run build:mobile && cap copy android && cap open android",
    "icons:generate": "node scripts/generate-icons.mjs && capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^6.3.1",
    "@capacitor/android": "^6.1.2",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.59.0",
    "@tosspayments/payment-widget-sdk": "^0.12.1",
    "axios": "^1.7.7",
    "firebase": "^11.10.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@types/google.maps": "^3.64.1",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
