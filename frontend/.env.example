# 백엔드 API 베이스 URL.
# 로컬: http://localhost:8000
# 프로덕션 (Vercel): https://atm-ledger.onrender.com (Render)
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth Client ID (선택). 비워두면 Google 로그인 버튼이 자동 숨김.
# Google Cloud Console → Credentials → OAuth 2.0 Client ID 발급 후 입력.
# 승인된 JavaScript 출처: https://moa365.com, https://www.moa365.com,
#                        https://moa.atm.ai.kr, http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Google Maps Platform Browser API Key (선택). 비워두면 지도 영역에 안내 메시지 표시.
# Google Cloud Console → APIs & Services → Credentials → API Key 발급.
# 필수 활성화 API: Maps JavaScript API, Places API (New), Geocoding API
# HTTP referrer 제한 권장: https://moa365.com/*, https://www.moa365.com/*,
#                        https://moa.atm.ai.kr/*, https://*.vercel.app/*,
#                        http://localhost:5173/*, http://localhost:4173/*
VITE_GOOGLE_MAPS_API_KEY=

